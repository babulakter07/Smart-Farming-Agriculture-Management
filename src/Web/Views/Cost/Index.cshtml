@model List<CostListDto>
@{
    ViewData["Title"] = "Costs";
    var farmId = ViewBag.FarmId as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>💰 Cost Register</h4>
    <a asp-action="Create" asp-route-farmId="@farmId" class="btn btn-success btn-sm">+ Add Cost</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover small mb-0">
            <thead class="table-light">
                <tr><th>Date</th><th>Category</th><th>Description</th><th>Batch</th><th>Crop</th><th>Amount (৳)</th><th>Type</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.CostDate.ToString("dd MMM yy")</td>
                        <td><span class="badge bg-secondary">@c.CostCategory</span></td>
                        <td>@(c.Description ?? "—")</td>
                        <td>@(c.BatchName ?? "—")</td>
                        <td>@(c.CropName ?? "—")</td>
                        <td class="fw-bold text-danger">@c.Amount.ToString("N2")</td>
                        <td>@(c.IsActual ? "Actual" : "Budgeted")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-outline-warning btn-sm">Edit</a>
                            <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this cost?')">
                                <input type="hidden" name="id" value="@c.Id" />
                                <input type="hidden" name="farmId" value="@farmId" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Del</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-muted text-center">No costs recorded.</td></tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="5" class="fw-bold text-end">Total Actual Costs:</td>
                    <td class="fw-bold text-danger">৳ @Model.Where(c => c.IsActual).Sum(c => c.Amount).ToString("N2")</td>
                    <td colspan="2"></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
