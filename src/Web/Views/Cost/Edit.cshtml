@model CostEditDto
@{
    ViewData["Title"] = "Edit Cost";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">✏️ Edit Cost Entry</div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="FarmId" type="hidden" />
                    <input asp-for="BatchId" type="hidden" />
                    <input asp-for="CropSeasonId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CostCategory" class="form-label"></label>
                            <select asp-for="CostCategory" class="form-select" asp-items="ViewBag.CategoryList"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CostDate" class="form-label"></label>
                            <input asp-for="CostDate" class="form-control" type="date" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <input asp-for="Description" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Amount" class="form-label">Amount (৳)</label>
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="IsActual" class="form-check-input" />
                                <label asp-for="IsActual" class="form-check-label">Actual</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Update</button>
                        <a asp-action="Index" asp-route-farmId="@Model.FarmId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
