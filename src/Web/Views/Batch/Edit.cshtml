@model BatchEditDto
@{
    ViewData["Title"] = "Edit Batch";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <div class="card shadow-sm">
            <div class="card-header bg-warning">✏️ Edit Batch</div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="FarmId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="BatchName" class="form-label"></label>
                            <input asp-for="BatchName" class="form-control" />
                            <span asp-validation-for="BatchName" class="text-danger"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Species" class="form-label"></label>
                            <select asp-for="Species" class="form-select" asp-items="Html.GetEnumSelectList<BatchSpecies>()"></select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<BatchStatus>()"></select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Breed" class="form-label"></label>
                            <input asp-for="Breed" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="StartDate" class="form-label"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="PlannedEndDate" class="form-label"></label>
                            <input asp-for="PlannedEndDate" class="form-control" type="date" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="InitialCount" class="form-label">Initial Count</label>
                            <input asp-for="InitialCount" class="form-control" type="number" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="InitialWeight_kg" class="form-label">Initial Weight (kg)</label>
                            <input asp-for="InitialWeight_kg" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="PurchaseCost" class="form-label">Purchase Cost (৳)</label>
                            <input asp-for="PurchaseCost" class="form-control" type="number" step="0.01" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check">
                                <input asp-for="IsEidTarget" class="form-check-input" />
                                <label asp-for="IsEidTarget" class="form-check-label">🕌 Eid Target</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-warning">Update Batch</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
