@model List<BatchListDto>
@{
    ViewData["Title"] = "Batches";
    var farmId = ViewBag.FarmId as int? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>🐄 Batches — @ViewBag.FarmName</h4>
    <div class="d-flex gap-2">
        <a asp-controller="Farm" asp-action="Details" asp-route-id="@farmId" class="btn btn-outline-secondary btn-sm">← Farm</a>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("FarmManager"))
        {
            <a asp-action="Create" asp-route-farmId="@farmId" class="btn btn-success btn-sm">+ New Batch</a>
        }
    </div>
</div>

<table class="table table-hover small">
    <thead class="table-light">
        <tr><th>Batch Name</th><th>Species</th><th>Breed</th><th>Started</th><th>Initial</th><th>Live</th><th>Status</th><th>Cost</th><th>Eid</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td><a asp-action="Details" asp-route-id="@b.Id">@b.BatchName</a></td>
                <td>@b.Species</td>
                <td>@(b.Breed ?? "—")</td>
                <td>@b.StartDate.ToString("dd MMM yy")</td>
                <td>@b.InitialCount</td>
                <td>@b.LiveCount</td>
                <td><span class="badge badge-status-@b.Status">@b.Status</span></td>
                <td>৳ @b.PurchaseCost.ToString("N0")</td>
                <td>@(b.IsEidTarget ? "🕌" : "")</td>
                <td class="d-flex gap-1">
                    <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-outline-success btn-sm">View</a>
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("FarmManager"))
                    {
                        <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-outline-warning btn-sm">Edit</a>
                    }
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="10" class="text-muted text-center">No batches. <a asp-action="Create" asp-route-farmId="@farmId">Create one</a>.</td></tr>
        }
    </tbody>
</table>
