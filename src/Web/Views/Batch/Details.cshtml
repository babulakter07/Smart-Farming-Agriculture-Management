@model BatchDetailDto
@{
    ViewData["Title"] = Model.BatchName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>🐄 @Model.BatchName <span class="badge badge-status-@Model.Status">@Model.Status</span> @(Model.IsEidTarget ? "🕌" : "")</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" asp-route-farmId="@Model.FarmId" class="btn btn-outline-secondary btn-sm">← Batches</a>
        <a asp-controller="Sale" asp-action="Create" asp-route-batchId="@Model.Id" class="btn btn-success btn-sm">+ Sale</a>
        <a asp-controller="Cost" asp-action="Create" asp-route-farmId="@Model.FarmId" asp-route-batchId="@Model.Id" class="btn btn-outline-primary btn-sm">+ Cost</a>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("FarmManager"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">Edit</a>
        }
    </div>
</div>

<!-- P&L Summary -->
<div class="row g-3 mb-4">
    <div class="col-md-2"><div class="card stat-card p-3"><div class="text-muted small">Live Animals</div><div class="fs-4 fw-bold text-success">@Model.LiveCount</div><div class="text-muted small">-@Model.TotalMortalities dead</div></div></div>
    <div class="col-md-2"><div class="card stat-card gold p-3"><div class="text-muted small">Avg Weight</div><div class="fs-4 fw-bold text-warning">@(Model.CurrentAvgWeight?.ToString("N2") ?? "—") kg</div></div></div>
    <div class="col-md-2"><div class="card stat-card blue p-3"><div class="text-muted small">FCR</div><div class="fs-4 fw-bold text-primary">@(Model.CurrentFCR?.ToString("N3") ?? "—")</div></div></div>
    <div class="col-md-2"><div class="card stat-card p-3"><div class="text-muted small">Feed Cost</div><div class="fs-5 fw-bold text-danger">৳ @Model.TotalFeedCost.ToString("N0")</div></div></div>
    <div class="col-md-2"><div class="card stat-card p-3"><div class="text-muted small">Revenue</div><div class="fs-5 fw-bold text-success">৳ @Model.TotalRevenue.ToString("N0")</div></div></div>
    <div class="col-md-2"><div class="card stat-card @(Model.GrossProfit >= 0 ? "" : "red") p-3"><div class="text-muted small">Gross P/L</div><div class="fs-5 fw-bold @(Model.GrossProfit >= 0 ? "text-success" : "text-danger")">৳ @Model.GrossProfit.ToString("N0")</div></div></div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-white fw-bold">📋 Batch Info</div>
            <div class="card-body small">
                <p><b>Farm:</b> @Model.FarmName</p>
                <p><b>Species:</b> @Model.Species</p>
                <p><b>Breed:</b> @(Model.Breed ?? "—")</p>
                <p><b>Start Date:</b> @Model.StartDate.ToString("dd MMM yyyy")</p>
                <p><b>Planned End:</b> @(Model.PlannedEndDate?.ToString("dd MMM yyyy") ?? "—")</p>
                <p><b>Purchase Cost:</b> ৳ @Model.PurchaseCost.ToString("N0")</p>
                @if (!string.IsNullOrEmpty(Model.Notes)) { <p><b>Notes:</b> @Model.Notes</p> }
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-white fw-bold d-flex justify-content-between">
                <span>💰 Sales</span>
                <a asp-controller="Sale" asp-action="Index" asp-route-batchId="@Model.Id" class="btn btn-outline-success btn-sm">View All</a>
            </div>
            <div class="card-body p-2">
                <p class="text-muted text-center small py-2">
                    <a asp-controller="Sale" asp-action="Create" asp-route-batchId="@Model.Id">Record a sale</a> to see P/L details.
                </p>
            </div>
        </div>
    </div>
</div>
