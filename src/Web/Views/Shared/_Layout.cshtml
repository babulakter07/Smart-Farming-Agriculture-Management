<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CAW Invest</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .sidebar { min-height: calc(100vh - 56px); background: #1a2218; }
        .sidebar .nav-link { color: #a8c0a0; padding: 0.6rem 1rem; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #a5d96a; background: #202d1e; border-radius: 4px; }
        .sidebar .nav-section { font-size: 0.7rem; letter-spacing: 2px; color: #6a8860; text-transform: uppercase; padding: 1rem 1rem 0.3rem; }
        .sidebar-brand { color: #a5d96a !important; font-weight: 700; font-size: 1.2rem; }
        body { background: #f4f7f4; }
        .topbar { background: #1a2218 !important; }
        .topbar .navbar-brand { color: #a5d96a !important; font-weight: 700; }
        .topbar .nav-link { color: #a8c0a0 !important; }
        .card { border: 1px solid #dde8dd; }
        .stat-card { border-left: 4px solid #4caf50; }
        .stat-card.gold { border-left-color: #f0b429; }
        .stat-card.blue { border-left-color: #5b9bd5; }
        .stat-card.red { border-left-color: #e05252; }
        .badge-status-Active { background: #d4edda; color: #155724; }
        .badge-status-Closed { background: #f8d7da; color: #721c24; }
        .badge-status-Planning { background: #fff3cd; color: #856404; }
        .badge-status-Selling { background: #cce5ff; color: #004085; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg topbar shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Dashboard" asp-action="Index">🌾 CAW Invest</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#topNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="topNav">
                <ul class="navbar-nav ms-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                👤 @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <nav class="col-md-2 d-none d-md-block sidebar py-3">
                    <div class="nav flex-column">
                        <span class="nav-section">Overview</span>
                        <a class="nav-link" asp-controller="Dashboard" asp-action="Index">📊 Dashboard</a>

                        <span class="nav-section">Livestock</span>
                        <a class="nav-link" asp-controller="Farm" asp-action="Index">🏡 Farms</a>

                        <span class="nav-section">Agriculture</span>
                        <a class="nav-link" asp-controller="Land" asp-action="Index" asp-route-farmId="0">🌾 Land Parcels</a>

                        <span class="nav-section">Finance</span>
                        <a class="nav-link" asp-controller="Cost" asp-action="Index" asp-route-farmId="0">💰 Costs</a>
                        <a class="nav-link" asp-controller="Sale" asp-action="Index" asp-route-batchId="0">📈 Sales</a>

                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <span class="nav-section">Admin</span>
                            <a class="nav-link" asp-controller="User" asp-action="Index">👥 Users</a>
                        }
                    </div>
                </nav>
                <main class="col-md-10 ms-sm-auto px-4 py-3">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @RenderBody()
                </main>
            }
            else
            {
                <main class="col-12">
                    @RenderBody()
                </main>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
