@model DashboardDto
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>📊 Farm Dashboard</h4>
    <small class="text-muted">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</small>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card p-3">
            <div class="text-muted small">Total Farms</div>
            <div class="fs-3 fw-bold text-success">@Model.TotalFarms</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card gold p-3">
            <div class="text-muted small">Active Batches</div>
            <div class="fs-3 fw-bold text-warning">@Model.ActiveBatches</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card blue p-3">
            <div class="text-muted small">Total Investment</div>
            <div class="fs-3 fw-bold text-primary">৳ @Model.TotalInvestment.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card @(Model.NetProfit >= 0 ? "" : "red") p-3">
            <div class="text-muted small">Net Profit</div>
            <div class="fs-3 fw-bold @(Model.NetProfit >= 0 ? "text-success" : "text-danger")">
                ৳ @Model.NetProfit.ToString("N0")
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3">
            <div class="text-muted small">Total Revenue</div>
            <div class="fs-4 fw-bold text-success">৳ @Model.TotalRevenue.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3">
            <div class="text-muted small">Total Costs</div>
            <div class="fs-4 fw-bold text-danger">৳ @Model.TotalCosts.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card p-3">
            <div class="text-muted small">Pending Tasks</div>
            <div class="fs-4 fw-bold text-warning">@Model.PendingTasks</div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card p-3">
            <div class="text-muted small">Eid Targets</div>
            <div class="fs-4 fw-bold text-success">@Model.EidTargetBatches 🕌</div>
        </div>
    </div>
</div>

@if (Model.WeatherAlerts.Any())
{
    <div class="alert alert-warning">
        <strong>⚡ Weather Alerts:</strong>
        <ul class="mb-0 mt-1">
            @foreach (var alert in Model.WeatherAlerts)
            {
                <li>@alert</li>
            }
        </ul>
    </div>
}

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-bold">🐄 Recent Batches</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr><th>Batch</th><th>Species</th><th>Status</th><th>Eid</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.RecentBatches)
                        {
                            <tr>
                                <td><a asp-controller="Batch" asp-action="Details" asp-route-id="@b.Id">@b.BatchName</a></td>
                                <td>@b.Species</td>
                                <td><span class="badge badge-status-@b.Status">@b.Status</span></td>
                                <td>@(b.IsEidTarget ? "🕌" : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white fw-bold">💰 Recent Sales</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 small">
                    <thead class="table-light">
                        <tr><th>Batch</th><th>Date</th><th>Revenue</th><th>Eid</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.RecentSales)
                        {
                            <tr>
                                <td>@s.BatchName</td>
                                <td>@s.SaleDate.ToString("dd MMM")</td>
                                <td class="text-success">৳ @s.TotalRevenue.ToString("N0")</td>
                                <td>@(s.IsEidSale ? "🕌" : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
