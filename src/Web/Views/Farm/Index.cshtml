@model List<FarmListDto>
@{
    ViewData["Title"] = "Farms";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>🏡 My Farms</h4>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("FarmManager"))
    {
        <a asp-action="Create" class="btn btn-success btn-sm">+ New Farm</a>
    }
</div>

<div class="row g-3">
    @foreach (var farm in Model)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h5 class="card-title">@farm.FarmName</h5>
                        <span class="badge @(farm.IsActive ? "bg-success" : "bg-secondary")">@(farm.IsActive ? "Active" : "Inactive")</span>
                    </div>
                    <p class="text-muted small mb-1">📍 @(farm.Location ?? "—")</p>
                    <p class="text-muted small mb-1">🌾 @farm.FarmType | 📐 @(farm.TotalArea?.ToString("N2") ?? "—") decimal</p>
                    <p class="small mb-2">🐄 @farm.BatchCount active batches</p>
                </div>
                <div class="card-footer bg-white border-0 d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@farm.Id" class="btn btn-outline-success btn-sm flex-fill">View</a>
                    <a asp-controller="Batch" asp-action="Index" asp-route-farmId="@farm.Id" class="btn btn-outline-secondary btn-sm flex-fill">Batches</a>
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("FarmManager"))
                    {
                        <a asp-action="Edit" asp-route-id="@farm.Id" class="btn btn-outline-warning btn-sm">Edit</a>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12"><p class="text-muted">No farms found. <a asp-action="Create">Create one</a>.</p></div>
    }
</div>
