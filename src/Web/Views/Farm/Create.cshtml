@model FarmCreateDto
@{
    ViewData["Title"] = "Create Farm";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">🏡 New Farm</div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="FarmName" class="form-label"></label>
                            <input asp-for="FarmName" class="form-control" />
                            <span asp-validation-for="FarmName" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FarmType" class="form-label"></label>
                            <select asp-for="FarmType" class="form-select" asp-items="Html.GetEnumSelectList<FarmType>()"></select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Location" class="form-label"></label>
                            <input asp-for="Location" class="form-control" placeholder="Upazila, District" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TotalArea" class="form-label">Total Area (decimal)</label>
                            <input asp-for="TotalArea" class="form-control" type="number" step="0.001" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Latitude" class="form-label"></label>
                            <input asp-for="Latitude" class="form-control" type="number" step="0.0000001" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Longitude" class="form-label"></label>
                            <input asp-for="Longitude" class="form-control" type="number" step="0.0000001" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-success">Create Farm</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
