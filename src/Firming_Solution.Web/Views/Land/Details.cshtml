@model Firming_Solution.Domain.Entities.LandParcel
@using Firming_Solution.Domain.Enums
@{
    ViewData["Title"] = Model.LandName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>All Land Parcels
    </a>
    <a asp-controller="CropSeason" asp-action="Create" asp-route-landId="@Model.Id" class="btn btn-caw-primary btn-sm">
        <i class="fas fa-plus me-1"></i>New Crop Season
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-info-circle me-2"></i>Parcel Details</div>
            <dl class="row mb-0" style="font-size:0.88rem;">
                <dt class="col-5" style="color:var(--caw-text-muted)">Land Name</dt>
                <dd class="col-7">@Model.LandName</dd>
                <dt class="col-5" style="color:var(--caw-text-muted)">Farm</dt>
                <dd class="col-7">@Model.Farm?.FarmName</dd>
                <dt class="col-5" style="color:var(--caw-text-muted)">Area</dt>
                <dd class="col-7">@Model.Area_Decimal.ToString("N2") Decimal</dd>
                <dt class="col-5" style="color:var(--caw-text-muted)">Ownership</dt>
                <dd class="col-7">@Model.OwnershipType</dd>
                @if (Model.LeaseCostPerSeason.HasValue)
                {
                    <dt class="col-5" style="color:var(--caw-text-muted)">Lease Cost</dt>
                    <dd class="col-7">৳ @Model.LeaseCostPerSeason.Value.ToString("N0")/season</dd>
                }
                <dt class="col-5" style="color:var(--caw-text-muted)">Soil Type</dt>
                <dd class="col-7">@(Model.SoilType ?? "—")</dd>
                <dt class="col-5" style="color:var(--caw-text-muted)">Last Tested</dt>
                <dd class="col-7">@(Model.LastTestedDate.HasValue ? Model.LastTestedDate.Value.ToString("dd MMM yyyy") : "Not tested")</dd>
            </dl>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="caw-card">
            <div class="caw-section-title">
                <i class="fas fa-seedling me-2"></i>Crop Seasons (@Model.CropSeasons.Count)
            </div>
            @if (Model.CropSeasons.Any())
            {
                <div class="table-responsive">
                    <table class="caw-table">
                        <thead><tr><th>Crop</th><th>Variety</th><th>Sow Date</th><th>Status</th><th>Actual Yield</th></tr></thead>
                        <tbody>
                            @foreach (var cs in Model.CropSeasons.OrderByDescending(c => c.SowDate))
                            {
                                <tr>
                                    <td style="color:var(--caw-text)">@cs.CropName</td>
                                    <td style="color:var(--caw-text-muted)">@(cs.Variety ?? "—")</td>
                                    <td style="color:var(--caw-text-muted)">@(cs.SowDate.HasValue ? cs.SowDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                    <td>
                                        @{
                                            var sCls = cs.Status switch {
                                                CropStatus.Planning => "badge-planning",
                                                CropStatus.Growing => "badge-active",
                                                CropStatus.Harvested => "badge-selling",
                                                CropStatus.Closed => "badge-closed",
                                                _ => ""
                                            };
                                        }
                                        <span class="caw-badge @sCls">@cs.Status</span>
                                    </td>
                                    <td style="color:var(--caw-text-muted)">@(cs.ActualYield_kg.HasValue ? $"{cs.ActualYield_kg.Value:N1} kg" : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="small" style="color:var(--caw-text-muted)">No crop seasons recorded.</p>
            }
        </div>
    </div>
</div>
