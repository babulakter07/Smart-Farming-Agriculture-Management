@model List<Firming_Solution.Domain.Entities.LandParcel>
@{
    ViewData["Title"] = "Land Parcels";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div></div>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>Add Parcel
        </a>
    }
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-map me-2"></i>Land Parcels (@Model.Count)</div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="caw-table">
                <thead>
                    <tr><th>Land Name</th><th>Farm</th><th>Area (Decimal)</th><th>Ownership</th><th>Soil Type</th><th>Last Tested</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var lp in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@lp.Id" class="text-gold">@lp.LandName</a>
                            </td>
                            <td style="color:var(--caw-text-muted)">@lp.Farm?.FarmName</td>
                            <td style="color:var(--caw-text-muted)">@lp.Area_Decimal.ToString("N2")</td>
                            <td style="color:var(--caw-text-muted)">@lp.OwnershipType</td>
                            <td style="color:var(--caw-text-muted)">@(lp.SoilType ?? "—")</td>
                            <td style="color:var(--caw-text-muted)">@(lp.LastTestedDate.HasValue ? lp.LastTestedDate.Value.ToString("dd MMM yyyy") : "—")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@lp.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <form asp-action="Delete" asp-route-id="@lp.Id" method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('Delete this land parcel?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="small text-center py-3" style="color:var(--caw-text-muted)">No land parcels found.</p>
    }
</div>
