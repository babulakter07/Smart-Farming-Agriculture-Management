@model List<Firming_Solution.Domain.Entities.LandParcel>
@using Firming_Solution.Domain.Enums
@{
    ViewData["Title"] = "জমির তালিকা";

    string OwnershipBn(OwnershipType t) => t switch {
        OwnershipType.Own      => "নিজস্ব",
        OwnershipType.Lease    => "ইজারা",
        OwnershipType.Mortgaged => "বন্ধকী",
        _ => t.ToString()
    };

    // Convert শতাংশ → কাঠা & বিঘা for display
    string AreaDisplay(decimal shotangsho)
    {
        var katha = shotangsho / 1.65289256m;
        var bigha = shotangsho / 33.0578512m;
        if (bigha >= 1)
            return $"{shotangsho:N2} শতাংশ ({bigha:N2} বিঘা)";
        if (katha >= 1)
            return $"{shotangsho:N2} শতাংশ ({katha:N2} কাঠা)";
        return $"{shotangsho:N2} শতাংশ";
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div></div>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>জমি যোগ করুন
        </a>
    }
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-map me-2"></i>জমির তালিকা (@Model.Count টি)</div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="caw-table">
                <thead>
                    <tr>
                        <th>পরিচিতি নাম</th>
                        <th>খামার</th>
                        <th>পরিমাণ</th>
                        <th>মালিকানা</th>
                        <th>মাটির ধরন</th>
                        <th>সর্বশেষ পরীক্ষা</th>
                        <th>কার্যক্রম</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lp in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Details" asp-route-id="@lp.Id" class="text-gold fw-bold">
                                    @(string.IsNullOrWhiteSpace(lp.LandName) ? "—" : lp.LandName)
                                </a>
                            </td>
                            <td style="color:var(--caw-text-muted)">@lp.Farm?.FarmName</td>
                            <td style="color:var(--caw-text-muted)">@AreaDisplay(lp.Area_Decimal)</td>
                            <td style="color:var(--caw-text-muted)">@OwnershipBn(lp.OwnershipType)</td>
                            <td style="color:var(--caw-text-muted)">@(lp.SoilType ?? "—")</td>
                            <td style="color:var(--caw-text-muted)">
                                @(lp.LastTestedDate.HasValue ? lp.LastTestedDate.Value.ToString("dd MMM yyyy") : "—")
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@lp.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <form asp-action="Delete" asp-route-id="@lp.Id" method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('এই জমির তথ্য মুছে ফেলবেন?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="small text-center py-3" style="color:var(--caw-text-muted)">কোনো জমির তথ্য পাওয়া যায়নি।</p>
    }
</div>
