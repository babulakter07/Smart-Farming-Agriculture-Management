@model Firming_Solution.Domain.Entities.WeatherLog
@{
    ViewData["Title"] = "Log Weather";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-cloud-sun me-2"></i>Log Farm Weather</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmId" class="caw-form-label">Farm <span class="text-danger">*</span></label>
                        <select asp-for="FarmId" asp-items="ViewBag.Farms" class="form-select">
                            <option value="">-- Select Farm --</option>
                        </select>
                        <span asp-validation-for="FarmId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LogDate" class="caw-form-label">Date <span class="text-danger">*</span></label>
                        <input asp-for="LogDate" class="form-control" type="date" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="WeatherCondition" class="caw-form-label">Condition</label>
                    <select asp-for="WeatherCondition" asp-items="Html.GetEnumSelectList<Firming_Solution.Domain.Enums.WeatherCondition>()" class="form-select"></select>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="TempMax_C" class="caw-form-label">Max Temp (°C)</label>
                        <input asp-for="TempMax_C" class="form-control" type="number" step="0.1" placeholder="36.0" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="TempMin_C" class="caw-form-label">Min Temp (°C)</label>
                        <input asp-for="TempMin_C" class="form-control" type="number" step="0.1" placeholder="22.0" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="Humidity_Pct" class="caw-form-label">Humidity (%)</label>
                        <input asp-for="Humidity_Pct" class="form-control" type="number" step="0.1" placeholder="75.0" />
                    </div>
                    <div class="col-md-3 mb-4">
                        <label asp-for="Rainfall_mm" class="caw-form-label">Rainfall (mm)</label>
                        <input asp-for="Rainfall_mm" class="form-control" type="number" step="0.1" placeholder="0.0" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>Save Log
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
