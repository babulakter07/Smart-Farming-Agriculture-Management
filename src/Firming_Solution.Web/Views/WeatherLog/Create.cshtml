@model Firming_Solution.Domain.Entities.WeatherLog
@{
    ViewData["Title"] = "আবহাওয়া লগ করুন";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-cloud-sun me-2"></i>খামারের আবহাওয়া লগ করুন</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmId" class="caw-form-label">খামার <span class="text-danger">*</span></label>
                        <select asp-for="FarmId" asp-items="ViewBag.Farms" class="form-select">
                            <option value="">-- খামার নির্বাচন করুন --</option>
                        </select>
                        <span asp-validation-for="FarmId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LogDate" class="caw-form-label">তারিখ <span class="text-danger">*</span></label>
                        <input asp-for="LogDate" class="form-control" type="date" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="WeatherCondition" class="caw-form-label">আবহাওয়ার অবস্থা</label>
                    <select asp-for="WeatherCondition" class="form-select">
                        <option value="Sunny">রোদেলা</option>
                        <option value="Cloudy">মেঘলা</option>
                        <option value="Rainy">বৃষ্টিপাত</option>
                        <option value="Storm">ঝড়</option>
                        <option value="Foggy">কুয়াশাচ্ছন্ন</option>
                    </select>
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label asp-for="TempMax_C" class="caw-form-label">সর্বোচ্চ তাপমাত্রা (°C)</label>
                        <input asp-for="TempMax_C" class="form-control" type="number" step="0.1" placeholder="৩৬.০" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="TempMin_C" class="caw-form-label">সর্বনিম্ন তাপমাত্রা (°C)</label>
                        <input asp-for="TempMin_C" class="form-control" type="number" step="0.1" placeholder="২২.০" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label asp-for="Humidity_Pct" class="caw-form-label">আর্দ্রতা (%)</label>
                        <input asp-for="Humidity_Pct" class="form-control" type="number" step="0.1" placeholder="৭৫.০" />
                    </div>
                    <div class="col-md-3 mb-4">
                        <label asp-for="Rainfall_mm" class="caw-form-label">বৃষ্টিপাত (মি.মি.)</label>
                        <input asp-for="Rainfall_mm" class="form-control" type="number" step="0.1" placeholder="০.০" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>আবহাওয়া লগ সংরক্ষণ করুন
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
