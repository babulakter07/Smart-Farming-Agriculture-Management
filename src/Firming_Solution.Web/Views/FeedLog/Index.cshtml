@model List<Firming_Solution.Domain.Entities.DailyFeedLog>
@{
    ViewData["Title"] = "খাবারের রেকর্ড";
    var batches = ViewBag.Batches as List<Firming_Solution.Domain.Entities.Batch>;
    int? selectedBatchId = ViewBag.SelectedBatchId;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex gap-2">
        <select name="batchId" class="form-select form-select-sm" style="width:220px;" onchange="this.form.submit()">
            <option value="">সব ব্যাচ</option>
            @if (batches != null)
            {
                foreach (var b in batches)
                {
                    if (selectedBatchId == b.Id)
                    {
                        <option value="@b.Id" selected="selected">@b.BatchName</option>
                    }
                    else
                    {
                        <option value="@b.Id">@b.BatchName</option>
                    }
                }
            }
        </select>
    </form>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager") || User.IsInRole("Worker"))
    {
        <a asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>খাবার লগ করুন
        </a>
    }
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-wheat-awn me-2"></i>খাবারের রেকর্ড — সর্বশেষ ১০০ টি</div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="caw-table">
                <thead>
                    <tr><th>তারিখ</th><th>ব্যাচ</th><th>খাবারের ধরন</th><th>পরিমাণ (কেজি)</th><th>মূল্য/কেজি</th><th>মোট খরচ</th><th>লগকারী</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var fl in Model)
                    {
                        <tr>
                            <td style="color:var(--caw-text-muted)">@fl.LogDate.ToString("dd MMM yyyy")</td>
                            <td><a asp-controller="Batch" asp-action="Details" asp-route-id="@fl.BatchId" class="text-gold">@fl.Batch?.BatchName</a></td>
                            <td style="color:var(--caw-text)">@fl.FeedType?.FeedName</td>
                            <td style="color:var(--caw-text-muted)">@fl.Quantity_kg.ToString("N2")</td>
                            <td style="color:var(--caw-text-muted)">৳ @fl.PricePerKg.ToString("N2")</td>
                            <td class="profit-positive">৳ @((fl.Quantity_kg * fl.PricePerKg).ToString("N0"))</td>
                            <td style="color:var(--caw-text-muted)">@(fl.LoggedBy?.FullName ?? fl.LoggedBy?.UserName ?? "—")</td>
                            <td>
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
                                {
                                    <form asp-action="Delete" asp-route-id="@fl.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('এই খাবার লগ মুছে ফেলবেন?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="small text-center py-3" style="color:var(--caw-text-muted)">কোনো খাবার লগ পাওয়া যায়নি।</p>
    }
</div>
