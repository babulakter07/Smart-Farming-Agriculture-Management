@model Firming_Solution.Domain.Entities.Sale
@{
    ViewData["Title"] = "Record Sale";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-cash-register me-2"></i>Record Sale</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="BatchId" class="caw-form-label">Batch <span class="text-danger">*</span></label>
                    <select asp-for="BatchId" asp-items="ViewBag.Batches" class="form-select">
                        <option value="">-- Select Batch --</option>
                    </select>
                    <span asp-validation-for="BatchId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="SaleDate" class="caw-form-label">Sale Date <span class="text-danger">*</span></label>
                        <input asp-for="SaleDate" class="form-control" type="date" />
                        <span asp-validation-for="SaleDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Quantity" class="caw-form-label">Quantity (heads)</label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" placeholder="100" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TotalWeight_kg" class="caw-form-label">Total Weight (kg)</label>
                        <input asp-for="TotalWeight_kg" class="form-control" type="number" step="0.01" placeholder="250.00"
                               oninput="calcRevenue()" />
                        <div class="small mt-1" style="color:var(--caw-text-muted)">If weight provided, revenue = Weight × Price/kg</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="PricePerKg" class="caw-form-label">Price per kg (৳)</label>
                        <input asp-for="PricePerKg" class="form-control" type="number" step="0.01" placeholder="0.00"
                               oninput="calcRevenue()" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="TotalRevenue" class="caw-form-label">Total Revenue (৳) <span class="text-danger">*</span></label>
                    <input asp-for="TotalRevenue" class="form-control" type="number" step="0.01" id="revenueField" placeholder="0.00" />
                    <span asp-validation-for="TotalRevenue" class="text-danger small"></span>
                    <div class="small mt-1" style="color:var(--caw-text-muted)">Auto-calculated from weight × price, or enter manually.</div>
                </div>

                <div class="mb-3">
                    <label asp-for="BuyerName" class="caw-form-label">Buyer Name</label>
                    <input asp-for="BuyerName" class="form-control" placeholder="Rahman Trading Co." />
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsEidSale" class="form-check-input" type="checkbox" />
                    <label asp-for="IsEidSale" class="form-check-label" style="color:var(--caw-text)">
                        <i class="fas fa-moon text-gold me-1"></i>Eid Sale
                    </label>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="caw-form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>Record Sale
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function calcRevenue() {
            var weight = parseFloat(document.getElementById('TotalWeight_kg')?.value) || 0;
            var price = parseFloat(document.getElementById('PricePerKg')?.value) || 0;
            if (weight > 0 && price > 0) {
                document.getElementById('revenueField').value = (weight * price).toFixed(2);
            }
        }
    </script>
}
