@model List<Firming_Solution.Domain.Entities.Sale>
@{
    ViewData["Title"] = "বিক্রয়ের ইতিহাস";
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0m;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>বিক্রয়ে ফিরুন
    </a>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>বিক্রয় রেকর্ড করুন
        </a>
    }
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="caw-card caw-stat-card info text-center">
            <div class="caw-card-title">সর্বকালীন মোট আয়</div>
            <div class="caw-card-value profit-positive" style="font-size:1.5rem;">৳ @totalRevenue.ToString("N0")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="caw-card caw-stat-card text-center">
            <div class="caw-card-title">মোট বিক্রয় রেকর্ড</div>
            <div class="caw-card-value">@Model.Count</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="caw-card caw-stat-card gold text-center">
            <div class="caw-card-title">ঈদ বিক্রয়</div>
            <div class="caw-card-value text-gold">@Model.Count(s => s.IsEidSale)</div>
        </div>
    </div>
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-history me-2"></i>সম্পূর্ণ বিক্রয় ইতিহাস</div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="caw-table">
                <thead>
                    <tr><th>তারিখ</th><th>ব্যাচ</th><th>খামার</th><th>পরিমাণ</th><th>ওজন (কেজি)</th><th>মূল্য/কেজি</th><th>আয়</th><th>ক্রেতা</th><th>ঈদ?</th></tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td style="color:var(--caw-text-muted)">@s.SaleDate.ToString("dd MMM yyyy")</td>
                            <td><a asp-controller="Batch" asp-action="Details" asp-route-id="@s.BatchId" class="text-gold">@s.Batch?.BatchName</a></td>
                            <td style="color:var(--caw-text-muted)">@s.Batch?.Farm?.FarmName</td>
                            <td style="color:var(--caw-text-muted)">@(s.Quantity?.ToString() ?? "—")</td>
                            <td style="color:var(--caw-text-muted)">@(s.TotalWeight_kg.HasValue ? $"{s.TotalWeight_kg.Value:N1}" : "—")</td>
                            <td style="color:var(--caw-text-muted)">৳ @s.PricePerKg.ToString("N2")</td>
                            <td class="profit-positive fw-bold">৳ @s.TotalRevenue.ToString("N0")</td>
                            <td style="color:var(--caw-text-muted)">@(s.BuyerName ?? "—")</td>
                            <td>
                                @if (s.IsEidSale) { <i class="fas fa-moon text-gold"></i> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="small text-center py-3" style="color:var(--caw-text-muted)">এখনো কোনো বিক্রয় নেই।</p>
    }
</div>
