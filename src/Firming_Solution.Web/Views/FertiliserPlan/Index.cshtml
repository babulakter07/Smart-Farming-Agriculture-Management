@model List<Firming_Solution.Domain.Entities.FertiliserPlan>
@{
    ViewData["Title"] = "Fertiliser Plans";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div></div>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>New Plan
        </a>
    }
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-flask me-2"></i>Fertiliser Plans</div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="caw-table">
                <thead>
                    <tr><th>Fertiliser</th><th>Land</th><th>Crop Season</th><th>Apply Date</th><th>Dose (kg/Decimal)</th><th>Total Qty (kg)</th><th>Total Cost</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var fp in Model)
                    {
                        <tr>
                            <td style="color:var(--caw-text)">@fp.FertiliserName</td>
                            <td style="color:var(--caw-text-muted)">@fp.Land?.LandName</td>
                            <td style="color:var(--caw-text-muted)">@(fp.Season?.CropName ?? "—")</td>
                            <td style="color:var(--caw-text-muted)">@fp.ApplyDate.ToString("dd MMM yyyy")</td>
                            <td style="color:var(--caw-text-muted)">@(fp.DoseKgPerDecimal.HasValue ? fp.DoseKgPerDecimal.Value.ToString("N2") : "—")</td>
                            <td style="color:var(--caw-text-muted)">@(fp.TotalQuantity_kg.HasValue ? $"{fp.TotalQuantity_kg.Value:N1}" : "—")</td>
                            <td style="color:var(--caw-text-muted)">@(fp.TotalCost.HasValue ? $"৳ {fp.TotalCost.Value:N0}" : "—")</td>
                            <td>
                                @if (fp.IsApplied)
                                {
                                    <span class="caw-badge badge-done">Applied</span>
                                }
                                else
                                {
                                    <span class="caw-badge badge-pending">Pending</span>
                                }
                            </td>
                            <td>
                                @if (!fp.IsApplied && (User.IsInRole("SuperAdmin") || User.IsInRole("Manager")))
                                {
                                    <form asp-action="MarkApplied" asp-route-id="@fp.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-success btn-sm" title="Mark as Applied">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="small text-center py-3" style="color:var(--caw-text-muted)">No fertiliser plans found.</p>
    }
</div>
