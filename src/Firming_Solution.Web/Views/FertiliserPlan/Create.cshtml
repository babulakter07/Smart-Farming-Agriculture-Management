@model Firming_Solution.Domain.Entities.FertiliserPlan
@{
    ViewData["Title"] = "নতুন সার পরিকল্পনা";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-flask me-2"></i>নতুন সার প্রয়োগের পরিকল্পনা</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="LandId" class="caw-form-label">জমি <span class="text-danger">*</span></label>
                        <select asp-for="LandId" asp-items="ViewBag.Lands" class="form-select">
                            <option value="">-- জমি নির্বাচন করুন --</option>
                        </select>
                        <span asp-validation-for="LandId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="SeasonId" class="caw-form-label">ফসলের মৌসুম <span class="text-danger">*</span></label>
                        <select asp-for="SeasonId" asp-items="ViewBag.Seasons" class="form-select">
                            <option value="">-- মৌসুম নির্বাচন করুন --</option>
                        </select>
                        <span asp-validation-for="SeasonId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FertiliserName" class="caw-form-label">সারের নাম <span class="text-danger">*</span></label>
                        <input asp-for="FertiliserName" class="form-control" placeholder="ইউরিয়া, TSP, MoP..." />
                        <span asp-validation-for="FertiliserName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ApplyDate" class="caw-form-label">প্রয়োগের তারিখ <span class="text-danger">*</span></label>
                        <input asp-for="ApplyDate" class="form-control" type="date" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="DoseKgPerDecimal" class="caw-form-label">মাত্রা (কেজি/শতাংশ)</label>
                        <input asp-for="DoseKgPerDecimal" class="form-control" type="number" step="0.01" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="TotalQuantity_kg" class="caw-form-label">মোট পরিমাণ (কেজি)</label>
                        <input asp-for="TotalQuantity_kg" class="form-control" type="number" step="0.1" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="PricePerKg" class="caw-form-label">মূল্য/কেজি (৳)</label>
                        <input asp-for="PricePerKg" class="form-control" type="number" step="0.01" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="TotalCost" class="caw-form-label">মোট খরচ (৳)</label>
                    <input asp-for="TotalCost" class="form-control" type="number" step="0.01" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>পরিকল্পনা তৈরি করুন
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
