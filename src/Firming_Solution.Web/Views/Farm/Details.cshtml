@model Firming_Solution.Domain.Entities.Farm
@using Firming_Solution.Domain.Enums
@{
    ViewData["Title"] = Model.FarmName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>All Farms
    </a>
    <div class="d-flex gap-2">
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">
                <i class="fas fa-edit me-1"></i>Edit
            </a>
        }
        <a asp-controller="Batch" asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>New Batch
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Farm Info -->
    <div class="col-lg-4">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-info-circle me-2"></i>Farm Details</div>
            <dl class="row mb-0" style="font-size:0.88rem;">
                <dt class="col-5" style="color:var(--caw-text-muted)">Name</dt>
                <dd class="col-7">@Model.FarmName</dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">Type</dt>
                <dd class="col-7">@Model.FarmType</dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">Location</dt>
                <dd class="col-7">@(Model.Location ?? "—")</dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">Area</dt>
                <dd class="col-7">@(Model.TotalArea.HasValue ? $"{Model.TotalArea:N2} Ha" : "—")</dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">GPS</dt>
                <dd class="col-7" style="font-size:0.78rem;">
                    @(Model.Latitude.HasValue ? $"{Model.Latitude:N6}, {Model.Longitude:N6}" : "—")
                </dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">Owner</dt>
                <dd class="col-7">@(Model.Owner?.FullName ?? Model.Owner?.UserName ?? "—")</dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">Status</dt>
                <dd class="col-7">
                    @if (Model.IsActive)
                    {
                        <span class="caw-badge badge-active">Active</span>
                    }
                    else
                    {
                        <span class="caw-badge badge-closed">Inactive</span>
                    }
                </dd>

                <dt class="col-5" style="color:var(--caw-text-muted)">Created</dt>
                <dd class="col-7" style="color:var(--caw-text-muted)">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
            </dl>
        </div>

        <!-- Investments Summary -->
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-piggy-bank me-2"></i>Investments</div>
            @if (Model.Investments.Any())
            {
                <div class="text-gold fw-bold fs-5">৳ @Model.Investments.Sum(i => i.Amount).ToString("N0")</div>
                <div class="small mt-1" style="color:var(--caw-text-muted)">@Model.Investments.Count investment records</div>
            }
            else
            {
                <p class="small" style="color:var(--caw-text-muted)">No investments recorded.</p>
            }
            <a asp-controller="Investment" asp-action="Create" class="btn btn-outline-success btn-sm mt-2">
                <i class="fas fa-plus me-1"></i>Log Investment
            </a>
        </div>
    </div>

    <!-- Batches -->
    <div class="col-lg-8">
        <div class="caw-card">
            <div class="caw-section-title">
                <i class="fas fa-layer-group me-2"></i>Batches (@Model.Batches.Count)
                <a asp-controller="Batch" asp-action="Create" class="float-end btn btn-caw-primary btn-sm">
                    <i class="fas fa-plus me-1"></i>New
                </a>
            </div>
            @if (Model.Batches.Any())
            {
                <div class="table-responsive">
                    <table class="caw-table">
                        <thead>
                            <tr><th>Batch</th><th>Species</th><th>Count</th><th>Start Date</th><th>Status</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var b in Model.Batches.OrderByDescending(b => b.CreatedAt))
                            {
                                var bCls = b.Status switch {
                                    BatchStatus.Active => "badge-active",
                                    BatchStatus.Planning => "badge-planning",
                                    BatchStatus.Selling => "badge-selling",
                                    BatchStatus.Closed => "badge-closed",
                                    _ => ""
                                };
                                <tr>
                                    <td><a asp-controller="Batch" asp-action="Details" asp-route-id="@b.Id" class="text-gold">@b.BatchName</a></td>
                                    <td style="color:var(--caw-text-muted)">@b.Species</td>
                                    <td style="color:var(--caw-text-muted)">@b.InitialCount</td>
                                    <td style="color:var(--caw-text-muted)">@b.StartDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="caw-badge @bCls">@b.Status</span></td>
                                    <td>
                                        <a asp-controller="Batch" asp-action="Details" asp-route-id="@b.Id" class="btn btn-outline-secondary btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="small" style="color:var(--caw-text-muted)">No batches yet.</p>
            }
        </div>

        <!-- Land Parcels -->
        <div class="caw-card">
            <div class="caw-section-title">
                <i class="fas fa-map me-2"></i>Land Parcels (@Model.LandParcels.Count)
                <a asp-controller="Land" asp-action="Create" class="float-end btn btn-outline-success btn-sm">
                    <i class="fas fa-plus me-1"></i>New
                </a>
            </div>
            @if (Model.LandParcels.Any())
            {
                <div class="table-responsive">
                    <table class="caw-table">
                        <thead><tr><th>Parcel Name</th><th>Area (Ha)</th><th>Soil Type</th><th></th></tr></thead>
                        <tbody>
                            @foreach (var lp in Model.LandParcels)
                            {
                                <tr>
                                    <td style="color:var(--caw-text)">@lp.LandName</td>
                                    <td style="color:var(--caw-text-muted)">@lp.Area_Decimal.ToString("N2")</td>
                                    <td style="color:var(--caw-text-muted)">@(lp.SoilType ?? "—")</td>
                                    <td>
                                        <a asp-controller="Land" asp-action="Details" asp-route-id="@lp.Id" class="btn btn-outline-secondary btn-sm">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="small" style="color:var(--caw-text-muted)">No land parcels recorded.</p>
            }
        </div>
    </div>
</div>
