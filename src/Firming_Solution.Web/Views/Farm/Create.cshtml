@model Firming_Solution.Domain.Entities.Farm
@{
    ViewData["Title"] = "নতুন খামার তৈরি";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-tractor me-2"></i>নতুন খামার তৈরি করুন</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FarmName" class="caw-form-label">খামারের নাম <span class="text-danger">*</span></label>
                    <input asp-for="FarmName" class="form-control" placeholder="CAW গ্রিন ফার্ম" />
                    <span asp-validation-for="FarmName" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmType" class="caw-form-label">খামারের ধরন <span class="text-danger">*</span></label>
                        <select asp-for="FarmType" class="form-select">
                            <option value="Livestock">প্রাণিসম্পদ</option>
                            <option value="Agriculture">কৃষি</option>
                            <option value="Mixed">মিশ্র</option>
                        </select>
                        <span asp-validation-for="FarmType" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="TotalArea" class="caw-form-label">মোট আয়তন (শতাংশ)</label>
                        <input asp-for="TotalArea" class="form-control" type="number" step="0.01" placeholder="৫.৫০" />
                        <span asp-validation-for="TotalArea" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="caw-form-label">অবস্থান / ঠিকানা</label>
                    <input asp-for="Location" class="form-control" placeholder="গ্রাম, উপজেলা, জেলা" />
                    <span asp-validation-for="Location" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Latitude" class="caw-form-label">অক্ষাংশ (GPS)</label>
                        <input asp-for="Latitude" class="form-control" type="number" step="0.000001" placeholder="23.810331" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Longitude" class="caw-form-label">দ্রাঘিমাংশ (GPS)</label>
                        <input asp-for="Longitude" class="form-control" type="number" step="0.000001" placeholder="90.412521" />
                    </div>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label" style="color:var(--caw-text)">খামার সক্রিয়</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>খামার তৈরি করুন
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
