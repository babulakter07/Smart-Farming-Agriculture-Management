@model Firming_Solution.Domain.Entities.Farm
@{
    ViewData["Title"] = "খামার সম্পাদনা";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-edit me-2"></i>খামার সম্পাদনা — @Model.FarmName</div>
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FarmName" class="caw-form-label">খামারের নাম <span class="text-danger">*</span></label>
                    <input asp-for="FarmName" class="form-control" />
                    <span asp-validation-for="FarmName" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmType" class="caw-form-label">খামারের ধরন</label>
                        <select asp-for="FarmType" class="form-select">
                            <option value="Livestock">প্রাণিসম্পদ</option>
                            <option value="Agriculture">কৃষি</option>
                            <option value="Mixed">মিশ্র</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="TotalArea" class="caw-form-label">মোট আয়তন (শতাংশ)</label>
                        <input asp-for="TotalArea" class="form-control" type="number" step="0.01" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="caw-form-label">অবস্থান</label>
                    <input asp-for="Location" class="form-control" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Latitude" class="caw-form-label">অক্ষাংশ</label>
                        <input asp-for="Latitude" class="form-control" type="number" step="0.000001" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Longitude" class="caw-form-label">দ্রাঘিমাংশ</label>
                        <input asp-for="Longitude" class="form-control" type="number" step="0.000001" />
                    </div>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label" style="color:var(--caw-text)">খামার সক্রিয়</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>পরিবর্তন সংরক্ষণ করুন
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
