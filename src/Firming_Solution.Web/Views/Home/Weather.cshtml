@{
    ViewData["Title"] = "আবহাওয়ার পূর্বাভাস";
    var weatherData = ViewBag.WeatherData as dynamic[];
}

<section style="padding:3rem 0; background:var(--caw-bg);">
    <div class="container">
        <div class="caw-section-heading">
            <i class="fas fa-cloud-sun-rain"></i>
            <h2>বাংলাদেশ কৃষি আবহাওয়ার পূর্বাভাস</h2>
        </div>
        <p style="color:var(--caw-text-muted)" class="mb-4">
            বাংলাদেশের প্রধান কৃষি অঞ্চলের দৈনিক আবহাওয়া পরিস্থিতি। সেচ, ফসল কাটা,
            স্প্রে করা ও মাঠের কাজ পরিকল্পনা করতে এই পূর্বাভাস ব্যবহার করুন।
        </p>

        <div class="row g-4 mb-5">
            @if (weatherData != null)
            {
                foreach (var w in weatherData)
                {
                    <div class="col-sm-6 col-lg-4">
                        <div class="caw-weather-widget">
                            <div class="caw-weather-icon">
                                <i class="fas @w.Icon"></i>
                            </div>
                            <div class="caw-weather-temp">@w.Temp°C</div>
                            <div class="fw-bold mt-1 fs-5" style="color:var(--caw-text)">@w.City</div>
                            <div class="caw-weather-city mb-2">@w.Condition</div>
                            <p class="small mb-3" style="color:var(--caw-text-muted)">@w.Description</p>
                            <div class="d-flex justify-content-center gap-3 small" style="color:var(--caw-text-muted)">
                                <span><i class="fas fa-tint me-1 text-info"></i>@w.Humidity% আর্দ্রতা</span>
                                <span><i class="fas fa-wind me-1 text-caw"></i>@w.Wind কি.মি/ঘ.</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- আবহাওয়া অনুযায়ী কৃষি পরামর্শ -->
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-lightbulb me-2"></i>আবহাওয়া অনুযায়ী কৃষি পরামর্শ</div>
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="text-center p-3">
                        <i class="fas fa-sun fa-2x mb-2" style="color:#f5a623"></i>
                        <h6 style="color:var(--caw-gold)">রৌদ্রজ্জ্বল দিন</h6>
                        <p class="small" style="color:var(--caw-text-muted)">ফসল কাটা, শস্য শুকানো ও মাঠের কাজের জন্য আদর্শ। প্রাণীদের ছায়া ও তাজা পানির ব্যবস্থা নিশ্চিত করুন।</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center p-3">
                        <i class="fas fa-cloud fa-2x mb-2" style="color:#b0bec5"></i>
                        <h6 style="color:var(--caw-gold)">মেঘলা দিন</h6>
                        <p class="small" style="color:var(--caw-text-muted)">চারা রোপণ ও পাতায় স্প্রে করার জন্য উপযুক্ত। ছত্রাকজনিত রোগের ঝুঁকি পর্যবেক্ষণ করুন।</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center p-3">
                        <i class="fas fa-cloud-showers-heavy fa-2x mb-2" style="color:#81d4fa"></i>
                        <h6 style="color:var(--caw-gold)">বৃষ্টির দিন</h6>
                        <p class="small" style="color:var(--caw-text-muted)">খাবার ও ওষুধের মজুদ রক্ষা করুন। রাসায়নিক স্প্রে এড়িয়ে চলুন। প্রাণীর খামারে পানি নিষ্কাশন পরীক্ষা করুন।</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="text-center p-3">
                        <i class="fas fa-bolt fa-2x mb-2" style="color:#ffd54f"></i>
                        <h6 style="color:var(--caw-gold)">ঝড়ের সতর্কতা</h6>
                        <p class="small" style="color:var(--caw-text-muted)">প্রাণিসম্পদকে আশ্রয়ে নিয়ে যান। পরিপক্ব ফসল কেটে নিন। খামারের ভবনের কাঠামোগত অবস্থা পরীক্ষা করুন।</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
