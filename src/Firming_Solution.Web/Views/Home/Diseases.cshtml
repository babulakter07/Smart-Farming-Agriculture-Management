@{
    ViewData["Title"] = "Common Animal Diseases";
}

<section style="padding:3rem 0;">
    <div class="container">
        <div class="caw-section-heading">
            <i class="fas fa-virus"></i>
            <h2>Common Animal Diseases Reference</h2>
        </div>
        <p style="color:var(--caw-text-muted)" class="mb-4">
            Comprehensive guide to common livestock diseases in Bangladesh.
            Early detection is key — consult a veterinarian immediately if you suspect an outbreak.
        </p>

        <!-- Cattle Diseases -->
        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-cow me-2"></i>Cattle Diseases</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Foot and Mouth Disease (FMD)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> High fever (40–41°C), blisters on mouth, tongue, feet and teats, excessive salivation, lameness, reduced milk yield.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Vaccinate every 6 months, quarantine new animals for 3 weeks, restrict farm visitors, disinfect vehicles.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Supportive care, antiseptic mouth washes, anti-inflammatory drugs. Contact vet immediately.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Highly contagious via direct contact, contaminated feed, water, and wind.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Brucellosis (Contagious Abortion)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Abortion in late pregnancy (7th–9th month), retained placenta, infertility, swollen joints, orchitis in bulls.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Test and cull infected animals, vaccinate female calves (3–8 months), pasteurise milk, use gloves when handling aborted material.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> No effective treatment — infected animals should be culled. Zoonotic risk to humans.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Via aborted material, milk, urine, and semen.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Blackleg (Black Quarter)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Sudden death (young cattle 6 months–2 years), hot painful swelling of muscles (shoulder, thigh), high fever, depression.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Annual vaccination before monsoon season, avoid waterlogged pastures, proper wound care.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Penicillin G at very early stage; usually fatal before treatment possible.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Clostridium chauvoei spores in soil, ingested via grazing.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Mastitis</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Hot, red, swollen udder; abnormal watery or clotted milk; fever; reduced milk production.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Proper milking technique and hygiene, post-milking teat dipping, dry cow therapy, clean bedding.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Intramammary antibiotics, supportive therapy, frequent stripping of affected quarter.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Contagious via milking equipment and hands.</p>
                </div>
            </div>
        </div>

        <!-- Poultry Diseases -->
        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-kiwi-bird me-2"></i>Poultry Diseases</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Avian Influenza (H5N1 Bird Flu)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Sudden high mortality, coughing, sneezing, nasal discharge, swollen head/comb/wattles, reduced or stopped egg production, twisted neck.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Strict biosecurity, avoid wild bird contact, regular disinfection, report to authorities immediately if suspected.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> No treatment — mass culling of infected flocks. Notify DLS (Department of Livestock Services) Bangladesh.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Airborne, direct contact with infected birds or feces. Zoonotic — avoid handling sick birds without protection.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Newcastle Disease (ND / Ranikhet)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Respiratory distress, greenish watery diarrhoea, nervous signs (twisted neck, paralysis), sudden high mortality.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Regular ND vaccination (B1, La Sota, Komarov strains), good biosecurity, keep water clean.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Supportive vitamins/electrolytes, antibiotics for secondary infections. No specific treatment.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Airborne, contaminated feed, water, equipment and fomites.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Gumboro Disease (IBD)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Sudden onset, depression, ruffled feathers, whitish watery diarrhoea, swollen bursa of Fabricius, high morbidity in 3–6 week chicks.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> IBD vaccination at 14 and 21 days, maintain strict hygiene, proper litter management.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Electrolytes, vitamins, control secondary infections. Mortality typically 20–30%.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Highly stable in environment; fecal-oral route.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Coccidiosis</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Bloody diarrhoea, pale comb, weight loss, huddling, high morbidity especially in young birds.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Anticoccidial in feed/water, dry litter management, rotational housing.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Amprolium, sulfonamides for 5–7 days. Vitamin K for hemorrhage.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Fecal-oral; oocysts in wet litter.</p>
                </div>
            </div>
        </div>

        <!-- Goat/Sheep Diseases -->
        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-paw me-2"></i>Goat &amp; Sheep Diseases</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Peste des Petits Ruminants (PPR / Goat Plague)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> High fever, nasal/eye discharge, mouth ulcers, diarrhoea, pneumonia. High mortality in young goats.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Annual PPR vaccination, quarantine new animals, restrict movement during outbreaks.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Supportive care, antibiotics for secondary infections. Report to DLS.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Direct contact with infected animals or their secretions.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-disease-card">
                    <h6><i class="fas fa-bug me-2"></i>Enterotoxaemia (Pulpy Kidney)</h6>
                    <p><strong style="color:#ef9a9a">Symptoms:</strong> Sudden death in well-nourished animals, convulsions, bloat, diarrhoea. Often found dead without prior signs.</p>
                    <p><strong style="color:#a5d6a7">Prevention:</strong> Annual vaccination, avoid sudden diet changes especially to lush pasture, reduce grain feeding.</p>
                    <p><strong style="color:#ffcc80">Treatment:</strong> Usually fatal before treatment. Antitoxin in early stages.</p>
                    <p><strong style="color:#81d4fa">Spread:</strong> Clostridium perfringens toxin from overgrown in gut; not contagious.</p>
                </div>
            </div>
        </div>

        <!-- Emergency Contact -->
        <div class="caw-card" style="border-left: 4px solid var(--caw-danger);">
            <div class="caw-section-title text-danger"><i class="fas fa-phone-alt me-2"></i>Emergency Veterinary Contacts — Bangladesh</div>
            <div class="row">
                <div class="col-md-4">
                    <p class="mb-1"><strong style="color:var(--caw-text)">DLS Hotline:</strong></p>
                    <p style="color:var(--caw-text-muted)">16358 (Department of Livestock Services)</p>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong style="color:var(--caw-text)">Animal Disease Helpline:</strong></p>
                    <p style="color:var(--caw-text-muted)">01713-198866</p>
                </div>
                <div class="col-md-4">
                    <p class="mb-1"><strong style="color:var(--caw-text)">Disease Reporting:</strong></p>
                    <p style="color:var(--caw-text-muted)">Report outbreaks to the nearest Upazila Livestock Office</p>
                </div>
            </div>
        </div>
    </div>
</section>
