@{
    ViewData["Title"] = "Fertilizer Guide";
}

<section style="padding:3rem 0;">
    <div class="container">
        <div class="caw-section-heading">
            <i class="fas fa-flask"></i>
            <h2>Comprehensive Fertilizer Guide</h2>
        </div>
        <p style="color:var(--caw-text-muted)" class="mb-4">
            A complete reference for fertilizer selection, dosage, and application timing
            for major crops grown in Bangladesh.
        </p>

        <!-- Macronutrient Fertilizers -->
        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-atom me-2"></i>Nitrogen Fertilizers (N)</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="caw-fert-card">
                    <h6><i class="fas fa-flask me-2"></i>Urea (46% N)</h6>
                    <p><strong style="color:#a5d6a7">Best Crops:</strong> Rice, jute, sugarcane, maize, vegetables.</p>
                    <p><strong style="color:#81d4fa">Application Rate:</strong> 150–250 kg/ha in 3 split doses.</p>
                    <p><strong style="color:#ffcc80">Timing:</strong> At transplanting, 15–20 days after, and at panicle initiation.</p>
                    <p><strong style="color:#ef9a9a">Caution:</strong> Volatilises quickly if surface-applied to dry soil. Apply immediately before irrigation.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-fert-card">
                    <h6><i class="fas fa-flask me-2"></i>Ammonium Sulphate (21% N + 24% S)</h6>
                    <p><strong style="color:#a5d6a7">Best Crops:</strong> Tea, potato, onion, cruciferous vegetables.</p>
                    <p><strong style="color:#81d4fa">Application Rate:</strong> 200–300 kg/ha split.</p>
                    <p><strong style="color:#ffcc80">Timing:</strong> Basal + top-dress after 3–4 weeks.</p>
                    <p><strong style="color:#ef9a9a">Caution:</strong> Acidifies soil — not ideal for acid soils. Good sulphur source.</p>
                </div>
            </div>
        </div>

        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-atom me-2"></i>Phosphate Fertilizers (P)</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="caw-fert-card">
                    <h6><i class="fas fa-flask me-2"></i>Triple Super Phosphate – TSP (46% P₂O₅)</h6>
                    <p><strong style="color:#a5d6a7">Best Crops:</strong> Legumes, oil seeds, wheat, potato.</p>
                    <p><strong style="color:#81d4fa">Application Rate:</strong> 75–120 kg/ha as basal dose.</p>
                    <p><strong style="color:#ffcc80">Timing:</strong> All at planting — phosphorus does not move in soil.</p>
                    <p><strong style="color:#ef9a9a">Caution:</strong> Broadcast and incorporate before sowing for best results.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-fert-card">
                    <h6><i class="fas fa-flask me-2"></i>DAP – Diammonium Phosphate (18% N + 46% P₂O₅)</h6>
                    <p><strong style="color:#a5d6a7">Best Crops:</strong> Cereals, vegetables, fruit trees.</p>
                    <p><strong style="color:#81d4fa">Application Rate:</strong> 100–150 kg/ha basal.</p>
                    <p><strong style="color:#ffcc80">Timing:</strong> At planting/sowing for root development.</p>
                    <p><strong style="color:#ef9a9a">Caution:</strong> Can raise soil pH slightly. Excellent starter fertilizer.</p>
                </div>
            </div>
        </div>

        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-atom me-2"></i>Potassium Fertilizers (K)</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="caw-fert-card">
                    <h6><i class="fas fa-flask me-2"></i>Muriate of Potash – MoP (60% K₂O)</h6>
                    <p><strong style="color:#a5d6a7">Best Crops:</strong> Potato, banana, sugarcane, coconut, rice.</p>
                    <p><strong style="color:#81d4fa">Application Rate:</strong> 80–150 kg/ha split in 2 doses.</p>
                    <p><strong style="color:#ffcc80">Timing:</strong> Half basal, half at 30–40 days after transplanting.</p>
                    <p><strong style="color:#ef9a9a">Caution:</strong> High chloride — avoid for tobacco and some vegetables. Improves drought and disease resistance.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="caw-fert-card">
                    <h6><i class="fas fa-flask me-2"></i>Sulphate of Potash – SoP (50% K₂O + 18% S)</h6>
                    <p><strong style="color:#a5d6a7">Best Crops:</strong> Tobacco, grapes, sensitive vegetables.</p>
                    <p><strong style="color:#81d4fa">Application Rate:</strong> 80–120 kg/ha.</p>
                    <p><strong style="color:#ffcc80">Timing:</strong> Basal or split application.</p>
                    <p><strong style="color:#ef9a9a">Caution:</strong> Chloride-free — premium option for chloride-sensitive crops.</p>
                </div>
            </div>
        </div>

        <!-- Micronutrients -->
        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-atom me-2"></i>Micronutrient Fertilizers</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="caw-fert-card">
                    <h6>Zinc Sulphate (21% Zn)</h6>
                    <p><strong style="color:#a5d6a7">For:</strong> Rice, wheat, maize on zinc-deficient soils.</p>
                    <p><strong style="color:#81d4fa">Rate:</strong> 10–20 kg/ha soil application or 0.5% foliar spray.</p>
                    <p><strong style="color:#ef9a9a">Deficiency Signs:</strong> Stunted growth, bronzing of older leaves.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="caw-fert-card">
                    <h6>Borax (11% B)</h6>
                    <p><strong style="color:#a5d6a7">For:</strong> Rapeseed, cauliflower, sunflower, legumes.</p>
                    <p><strong style="color:#81d4fa">Rate:</strong> 5–10 kg/ha basal or 0.1–0.25% foliar.</p>
                    <p><strong style="color:#ef9a9a">Deficiency Signs:</strong> Hollow stem, distorted growing tips, poor seed set.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="caw-fert-card">
                    <h6>Gypsum (CaSO₄ — 20% S + 23% Ca)</h6>
                    <p><strong style="color:#a5d6a7">For:</strong> Groundnut, sunflower, all legumes, saline soils.</p>
                    <p><strong style="color:#81d4fa">Rate:</strong> 200–400 kg/ha basal.</p>
                    <p><strong style="color:#ef9a9a">Note:</strong> Also improves soil structure and reclaims saline soils.</p>
                </div>
            </div>
        </div>

        <!-- Organic -->
        <h4 class="mb-3" style="color:var(--caw-gold)"><i class="fas fa-leaf me-2"></i>Organic Fertilizers</h4>
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="caw-fert-card">
                    <h6>Farmyard Manure (FYM)</h6>
                    <p><strong style="color:#a5d6a7">N-P-K:</strong> ~0.5 – 0.25 – 0.5%</p>
                    <p><strong style="color:#81d4fa">Rate:</strong> 5–15 tonnes/ha.</p>
                    <p>Improves soil structure, water holding capacity and microbial life. Well-composted FYM is best.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="caw-fert-card">
                    <h6>Poultry Manure</h6>
                    <p><strong style="color:#a5d6a7">N-P-K:</strong> ~3 – 2.5 – 2%</p>
                    <p><strong style="color:#81d4fa">Rate:</strong> 2–5 tonnes/ha.</p>
                    <p>High nutrient content; use composted form to avoid pathogen risk and ammonia burn.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="caw-fert-card">
                    <h6>Vermicompost</h6>
                    <p><strong style="color:#a5d6a7">N-P-K:</strong> ~1.5 – 1 – 1.5% + micronutrients</p>
                    <p><strong style="color:#81d4fa">Rate:</strong> 2–4 tonnes/ha.</p>
                    <p>Excellent for vegetables and nurseries. Improves root health and beneficial soil organisms.</p>
                </div>
            </div>
        </div>

        <!-- Application Schedule Table -->
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-table me-2"></i>Recommended Fertilizer Schedule — Major Bangladesh Crops</div>
            <div class="table-responsive">
                <table class="caw-table">
                    <thead>
                        <tr>
                            <th>Crop</th>
                            <th>N (Urea kg/ha)</th>
                            <th>P (TSP kg/ha)</th>
                            <th>K (MoP kg/ha)</th>
                            <th>Season</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>Boro Rice</td><td>200–250</td><td>80–100</td><td>80–100</td><td>Nov–May</td></tr>
                        <tr><td>Aman Rice</td><td>130–150</td><td>50–60</td><td>50–60</td><td>Jul–Nov</td></tr>
                        <tr><td>Wheat</td><td>150–180</td><td>90–100</td><td>60–80</td><td>Nov–Mar</td></tr>
                        <tr><td>Maize</td><td>200–250</td><td>100–120</td><td>80–100</td><td>Year round</td></tr>
                        <tr><td>Potato</td><td>130–150</td><td>100–130</td><td>120–150</td><td>Oct–Feb</td></tr>
                        <tr><td>Jute</td><td>150–180</td><td>50–60</td><td>40–50</td><td>Mar–Jul</td></tr>
                        <tr><td>Mustard</td><td>80–100</td><td>60–70</td><td>40–50</td><td>Oct–Jan</td></tr>
                        <tr><td>Tomato</td><td>150–200</td><td>100–120</td><td>100–120</td><td>Oct–Mar</td></tr>
                    </tbody>
                </table>
            </div>
            <p class="mt-2 small" style="color:var(--caw-text-muted)">
                * Rates are approximate — actual needs vary by soil test results, variety, and local conditions.
                Always conduct soil tests every 2–3 years for optimal recommendations.
            </p>
        </div>
    </div>
</section>
