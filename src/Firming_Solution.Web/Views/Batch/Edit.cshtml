@model Firming_Solution.Domain.Entities.Batch
@{
    ViewData["Title"] = "Edit Batch";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-edit me-2"></i>Edit Batch — @Model.BatchName</div>
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>
                <input type="hidden" asp-for="FarmId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="BatchName" class="caw-form-label">Batch Name <span class="text-danger">*</span></label>
                        <input asp-for="BatchName" class="form-control" />
                        <span asp-validation-for="BatchName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Species" class="caw-form-label">Species</label>
                        <select asp-for="Species" asp-items="Html.GetEnumSelectList<Firming_Solution.Domain.Enums.BatchSpecies>()" class="form-select"></select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Breed" class="caw-form-label">Breed</label>
                        <input asp-for="Breed" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Status" class="caw-form-label">Status</label>
                        <select asp-for="Status" asp-items="Html.GetEnumSelectList<Firming_Solution.Domain.Enums.BatchStatus>()" class="form-select"></select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="PlannedEndDate" class="caw-form-label">Planned End Date</label>
                    <input asp-for="PlannedEndDate" class="form-control" type="date" />
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsEidTarget" class="form-check-input" type="checkbox" />
                    <label asp-for="IsEidTarget" class="form-check-label" style="color:var(--caw-text)">
                        <i class="fas fa-moon text-gold me-1"></i>Eid Bazar Target
                    </label>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="caw-form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
