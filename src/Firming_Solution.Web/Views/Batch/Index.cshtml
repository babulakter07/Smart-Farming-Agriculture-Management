@model List<Firming_Solution.Domain.Entities.Batch>
@using Firming_Solution.Domain.Enums
@{
    ViewData["Title"] = "ব্যাচের তালিকা";
    var farms = ViewBag.Farms as List<Firming_Solution.Domain.Entities.Farm>;
    int? selectedFarmId = ViewBag.SelectedFarmId;

    string BatchStatusBn(BatchStatus s) => s switch {
        BatchStatus.Active   => "সক্রিয়",
        BatchStatus.Planning => "পরিকল্পনা",
        BatchStatus.Selling  => "বিক্রয়",
        BatchStatus.Closed   => "বন্ধ",
        _ => s.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <form method="get" class="d-flex gap-2">
        <select name="farmId" class="form-select form-select-sm" style="width:200px;" onchange="this.form.submit()">
            <option value="">সব খামার</option>
            @if (farms != null)
            {
                foreach (var f in farms)
                {
                    if (selectedFarmId == f.Id)
                    {
                        <option value="@f.Id" selected="selected">@f.FarmName</option>
                    }
                    else
                    {
                        <option value="@f.Id">@f.FarmName</option>
                    }
                }
            }
        </select>
    </form>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-caw-primary btn-sm">
            <i class="fas fa-plus me-1"></i>নতুন ব্যাচ
        </a>
    }
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-layer-group me-2"></i>ব্যাচের তালিকা (@Model.Count টি)</div>
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="caw-table">
                <thead>
                    <tr>
                        <th>ব্যাচের নাম</th>
                        <th>খামার</th>
                        <th>প্রজাতি</th>
                        <th>প্রাণীর সংখ্যা</th>
                        <th>শুরুর তারিখ</th>
                        <th>ঈদ?</th>
                        <th>অবস্থা</th>
                        <th>কার্যক্রম</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        var bCls = b.Status switch {
                            BatchStatus.Active   => "badge-active",
                            BatchStatus.Planning => "badge-planning",
                            BatchStatus.Selling  => "badge-selling",
                            BatchStatus.Closed   => "badge-closed",
                            _ => ""
                        };
                        <tr>
                            <td><a asp-action="Details" asp-route-id="@b.Id" class="text-gold fw-600">@b.BatchName</a></td>
                            <td style="color:var(--caw-text-muted)">@b.Farm?.FarmName</td>
                            <td style="color:var(--caw-text-muted)">@b.Species</td>
                            <td style="color:var(--caw-text-muted)">@b.InitialCount.ToString("N0")</td>
                            <td style="color:var(--caw-text-muted)">@b.StartDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (b.IsEidTarget)
                                {
                                    <i class="fas fa-moon text-gold" title="ঈদ টার্গেট"></i>
                                }
                            </td>
                            <td><span class="caw-badge @bCls">@BatchStatusBn(b.Status)</span></td>
                            <td>
                                <a asp-action="Details" asp-route-id="@b.Id" class="btn btn-outline-secondary btn-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Manager"))
                                {
                                    <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-outline-warning btn-sm ms-1">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                }
                                @if (User.IsInRole("SuperAdmin"))
                                {
                                    <form asp-action="Delete" asp-route-id="@b.Id" method="post" class="d-inline ms-1"
                                          onsubmit="return confirm('@b.BatchName ব্যাচটি মুছে ফেলবেন?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-4">
            <i class="fas fa-layer-group fa-3x mb-3" style="color:var(--caw-text-muted)"></i>
            <p style="color:var(--caw-text-muted)">কোনো ব্যাচ পাওয়া যায়নি।</p>
        </div>
    }
</div>
