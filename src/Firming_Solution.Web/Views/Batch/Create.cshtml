@model Firming_Solution.Domain.Entities.Batch
@{
    ViewData["Title"] = "Create Batch";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-plus-circle me-2"></i>Create New Batch</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmId" class="caw-form-label">Farm <span class="text-danger">*</span></label>
                        <select asp-for="FarmId" asp-items="ViewBag.Farms" class="form-select">
                            <option value="">-- Select Farm --</option>
                        </select>
                        <span asp-validation-for="FarmId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BatchName" class="caw-form-label">Batch Name <span class="text-danger">*</span></label>
                        <input asp-for="BatchName" class="form-control" placeholder="Broiler-Apr-2026" />
                        <span asp-validation-for="BatchName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Species" class="caw-form-label">Species <span class="text-danger">*</span></label>
                        <select asp-for="Species" asp-items="Html.GetEnumSelectList<Firming_Solution.Domain.Enums.BatchSpecies>()" class="form-select"></select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Breed" class="caw-form-label">Breed / Variety</label>
                        <input asp-for="Breed" class="form-control" placeholder="Ross 308, Murrah, etc." />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="InitialCount" class="caw-form-label">Initial Count <span class="text-danger">*</span></label>
                        <input asp-for="InitialCount" class="form-control" type="number" min="1" placeholder="500" />
                        <span asp-validation-for="InitialCount" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="InitialWeight_kg" class="caw-form-label">Initial Avg Weight (kg)</label>
                        <input asp-for="InitialWeight_kg" class="form-control" type="number" step="0.01" placeholder="0.45" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="PurchaseCost" class="caw-form-label">Purchase Cost (৳) <span class="text-danger">*</span></label>
                        <input asp-for="PurchaseCost" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        <span asp-validation-for="PurchaseCost" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="StartDate" class="caw-form-label">Start Date <span class="text-danger">*</span></label>
                        <input asp-for="StartDate" class="form-control" type="date" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="PlannedEndDate" class="caw-form-label">Planned End Date</label>
                        <input asp-for="PlannedEndDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Status" class="caw-form-label">Status</label>
                        <select asp-for="Status" asp-items="Html.GetEnumSelectList<Firming_Solution.Domain.Enums.BatchStatus>()" class="form-select"></select>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsEidTarget" class="form-check-input" type="checkbox" />
                    <label asp-for="IsEidTarget" class="form-check-label" style="color:var(--caw-text)">
                        <i class="fas fa-moon text-gold me-1"></i>Mark as Eid Bazar Target
                    </label>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="caw-form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Any additional notes..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>Create Batch
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
