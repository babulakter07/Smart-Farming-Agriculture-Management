@model Firming_Solution.Domain.Entities.Batch
@{
    ViewData["Title"] = "নতুন ব্যাচ তৈরি";
}

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-plus-circle me-2"></i>নতুন ব্যাচ তৈরি করুন</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmId" class="caw-form-label">খামার <span class="text-danger">*</span></label>
                        <select asp-for="FarmId" asp-items="ViewBag.Farms" class="form-select">
                            <option value="">-- খামার নির্বাচন করুন --</option>
                        </select>
                        <span asp-validation-for="FarmId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="BatchName" class="caw-form-label">ব্যাচের নাম <span class="text-danger">*</span></label>
                        <input asp-for="BatchName" class="form-control" placeholder="ব্রয়লার-এপ্রিল-২০২৬" />
                        <span asp-validation-for="BatchName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Species" class="caw-form-label">প্রজাতি <span class="text-danger">*</span></label>
                        <select asp-for="Species" class="form-select">
                            <option value="Cattle">গরু</option>
                            <option value="Poultry">মুরগি</option>
                            <option value="Fish">মাছ</option>
                            <option value="Goat">ছাগল</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Breed" class="caw-form-label">জাত / ভ্যারাইটি</label>
                        <input asp-for="Breed" class="form-control" placeholder="Ross 308, মুররা, ইত্যাদি" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="InitialCount" class="caw-form-label">প্রাথমিক সংখ্যা <span class="text-danger">*</span></label>
                        <input asp-for="InitialCount" class="form-control" type="number" min="1" placeholder="৫০০" />
                        <span asp-validation-for="InitialCount" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="InitialWeight_kg" class="caw-form-label">প্রাথমিক গড় ওজন (কেজি)</label>
                        <input asp-for="InitialWeight_kg" class="form-control" type="number" step="0.01" placeholder="০.৪৫" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="PurchaseCost" class="caw-form-label">ক্রয় মূল্য (৳) <span class="text-danger">*</span></label>
                        <input asp-for="PurchaseCost" class="form-control" type="number" step="0.01" placeholder="০.০০" />
                        <span asp-validation-for="PurchaseCost" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="StartDate" class="caw-form-label">শুরুর তারিখ <span class="text-danger">*</span></label>
                        <input asp-for="StartDate" class="form-control" type="date" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="PlannedEndDate" class="caw-form-label">পরিকল্পিত শেষ তারিখ</label>
                        <input asp-for="PlannedEndDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Status" class="caw-form-label">অবস্থা</label>
                        <select asp-for="Status" class="form-select">
                            <option value="Planning">পরিকল্পনা</option>
                            <option value="Active">সক্রিয়</option>
                            <option value="Selling">বিক্রয়</option>
                            <option value="Closed">বন্ধ</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsEidTarget" class="form-check-input" type="checkbox" />
                    <label asp-for="IsEidTarget" class="form-check-label" style="color:var(--caw-text)">
                        <i class="fas fa-moon text-gold me-1"></i>ঈদ বাজারের টার্গেট হিসেবে চিহ্নিত করুন
                    </label>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="caw-form-label">মন্তব্য</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="যেকোনো অতিরিক্ত তথ্য..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>ব্যাচ তৈরি করুন
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
