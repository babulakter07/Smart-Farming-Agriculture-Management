@model Firming_Solution.Domain.Entities.Investment
@{
    ViewData["Title"] = "বিনিয়োগ লগ করুন";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-piggy-bank me-2"></i>বিনিয়োগ লগ করুন</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmId" class="caw-form-label">খামার <span class="text-danger">*</span></label>
                        <select asp-for="FarmId" asp-items="ViewBag.Farms" class="form-select">
                            <option value="">-- খামার নির্বাচন করুন --</option>
                        </select>
                        <span asp-validation-for="FarmId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="InvestDate" class="caw-form-label">বিনিয়োগের তারিখ <span class="text-danger">*</span></label>
                        <input asp-for="InvestDate" class="form-control" type="date" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="caw-form-label">বিভাগ <span class="text-danger">*</span></label>
                        <select asp-for="Category" class="form-select">
                            <option value="LandPurchase">জমি ক্রয়</option>
                            <option value="Infrastructure">অবকাঠামো</option>
                            <option value="Equipment">সরঞ্জাম</option>
                            <option value="WorkingCapital">কার্যকরী মূলধন</option>
                            <option value="Other">অন্যান্য</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Source" class="caw-form-label">উৎস <span class="text-danger">*</span></label>
                        <select asp-for="Source" class="form-select">
                            <option value="OwnFunds">নিজস্ব তহবিল</option>
                            <option value="BankLoan">ব্যাংক ঋণ</option>
                            <option value="Investor">বিনিয়োগকারী</option>
                            <option value="Other">অন্যান্য</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Amount" class="caw-form-label">পরিমাণ (৳) <span class="text-danger">*</span></label>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" placeholder="০.০০" />
                    <span asp-validation-for="Amount" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="caw-form-label">বিবরণ</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="বিনিয়োগের বিস্তারিত..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-save me-2"></i>বিনিয়োগ লগ করুন
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
