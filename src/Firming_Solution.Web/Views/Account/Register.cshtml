@model Firming_Solution.Web.Models.RegisterViewModel
@{
    ViewData["Title"] = "নতুন ব্যবহারকারী নিবন্ধন";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-user-plus me-2"></i>নতুন ব্যবহারকারী নিবন্ধন</div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="caw-form-label">পূর্ণ নাম</label>
                    <input asp-for="FullName" class="form-control" placeholder="মোহাম্মদ আলী" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserName" class="caw-form-label">ব্যবহারকারীর নাম</label>
                    <input asp-for="UserName" class="form-control" placeholder="m.ali" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="caw-form-label">ইমেইল</label>
                    <input asp-for="Email" class="form-control" placeholder="mali@cawfarm.com" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="caw-form-label">মোবাইল নম্বর (ঐচ্ছিক)</label>
                    <input asp-for="Phone" class="form-control" placeholder="01XXXXXXXXX" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="caw-form-label">ভূমিকা</label>
                    <select asp-for="Role" class="form-select">
                        <option value="SuperAdmin">সুপার অ্যাডমিন</option>
                        <option value="Manager">ম্যানেজার</option>
                        <option value="Worker">কর্মী</option>
                        <option value="Accountant">হিসাবরক্ষক</option>
                        <option value="Viewer">দর্শক</option>
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="caw-form-label">পাসওয়ার্ড</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="কমপক্ষে ৮ অক্ষর, বড়হাতা, ছোটহাতা, সংখ্যা, প্রতীক" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="caw-form-label">পাসওয়ার্ড নিশ্চিত করুন</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="পাসওয়ার্ড পুনরায় লিখুন" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-user-plus me-2"></i>ব্যবহারকারী তৈরি করুন
                    </button>
                    <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
