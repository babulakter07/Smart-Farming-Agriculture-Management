@model Firming_Solution.Web.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register New User";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-user-plus me-2"></i>Register New User</div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="caw-form-label">Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="Mohammad Ali" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserName" class="caw-form-label">Username</label>
                    <input asp-for="UserName" class="form-control" placeholder="m.ali" />
                    <span asp-validation-for="UserName" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="caw-form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="mali@cawfarm.com" type="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="caw-form-label">Phone (optional)</label>
                    <input asp-for="Phone" class="form-control" placeholder="01XXXXXXXXX" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Role" class="caw-form-label">Role</label>
                    <select asp-for="Role" asp-items="Html.GetEnumSelectList<Firming_Solution.Domain.Enums.UserRole>()" class="form-select"></select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="caw-form-label">Password</label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Min 8 chars, upper, lower, digit, symbol" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="caw-form-label">Confirm Password</label>
                    <input asp-for="ConfirmPassword" class="form-control" type="password" placeholder="Repeat password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-primary flex-fill">
                        <i class="fas fa-user-plus me-2"></i>Create User
                    </button>
                    <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
