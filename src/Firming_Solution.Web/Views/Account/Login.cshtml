@model Firming_Solution.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "লগইন";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="caw-login-wrapper">
    <div class="caw-login-card">
        <div class="caw-login-logo">
            <i class="fas fa-leaf"></i>
            <h2>CAW ইনভেস্ট</h2>
            <p>কৃষি ও খামার ব্যবস্থাপনা সিস্টেম</p>
        </div>

        <form asp-action="Login" method="post">
            <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="caw-form-label">ইমেইল / ব্যবহারকারীর নাম</label>
                <input asp-for="Email" class="caw-input" placeholder="you@example.com" autocomplete="username" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="caw-form-label">পাসওয়ার্ড</label>
                <input asp-for="Password" class="caw-input" type="password" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3 d-flex align-items-center gap-2">
                <input asp-for="RememberMe" class="form-check-input mt-0" style="width:1.1em; height:1.1em;" />
                <label asp-for="RememberMe" class="caw-form-label mb-0">৮ ঘণ্টা লগইন মনে রাখুন</label>
            </div>

            <button type="submit" class="btn btn-caw-primary w-100 py-2 fw-600">
                <i class="fas fa-sign-in-alt me-2"></i>লগইন করুন
            </button>
        </form>

        <div class="text-center mt-3">
            <a asp-controller="Home" asp-action="Index" class="small" style="color:var(--caw-text-muted)">
                <i class="fas fa-arrow-left me-1"></i>পাবলিক সাইটে ফিরে যান
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
