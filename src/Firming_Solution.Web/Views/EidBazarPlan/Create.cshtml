@model Firming_Solution.Domain.Entities.EidBazarPlan
@{
    ViewData["Title"] = "নতুন ঈদ বাজার পরিকল্পনা";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-7">
        <div class="caw-card">
            <div class="caw-section-title"><i class="fas fa-moon text-gold me-2"></i>নতুন ঈদ বাজার পরিকল্পনা</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FarmId" class="caw-form-label">খামার <span class="text-danger">*</span></label>
                        <select asp-for="FarmId" asp-items="ViewBag.Farms" class="form-select">
                            <option value="">-- খামার নির্বাচন করুন --</option>
                        </select>
                        <span asp-validation-for="FarmId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EidType" class="caw-form-label">ঈদের ধরন <span class="text-danger">*</span></label>
                        <select asp-for="EidType" class="form-select">
                            <option value="EidUlAdha">ঈদুল আযহা</option>
                            <option value="EidUlFitr">ঈদুল ফিতর</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="EidDate" class="caw-form-label">ঈদের তারিখ <span class="text-danger">*</span></label>
                        <input asp-for="EidDate" class="form-control" type="date" />
                        <span asp-validation-for="EidDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LinkedBatchId" class="caw-form-label">সংযুক্ত ব্যাচ (ঈদ টার্গেট)</label>
                        <select asp-for="LinkedBatchId" asp-items="ViewBag.Batches" class="form-select">
                            <option value="">-- নেই --</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="TargetAnimals" class="caw-form-label">টার্গেট প্রাণীর সংখ্যা</label>
                        <input asp-for="TargetAnimals" class="form-control" type="number" min="1" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="TargetWeightPerAnimal" class="caw-form-label">প্রতি প্রাণীর লক্ষ্য ওজন (কেজি)</label>
                        <input asp-for="TargetWeightPerAnimal" class="form-control" type="number" step="0.1" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="ExpectedPricePerKg" class="caw-form-label">প্রত্যাশিত মূল্য/কেজি (৳)</label>
                        <input asp-for="ExpectedPricePerKg" class="form-control" type="number" step="0.01" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="ExpectedRevenue" class="caw-form-label">প্রত্যাশিত আয় (৳)</label>
                    <input asp-for="ExpectedRevenue" class="form-control" type="number" step="0.01" />
                    <div class="small mt-1" style="color:var(--caw-text-muted)">
                        = টার্গেট প্রাণী × লক্ষ্য ওজন/প্রাণী × প্রত্যাশিত মূল্য/কেজি
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-caw-gold flex-fill">
                        <i class="fas fa-save me-2"></i>পরিকল্পনা তৈরি করুন
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>বাতিল
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
