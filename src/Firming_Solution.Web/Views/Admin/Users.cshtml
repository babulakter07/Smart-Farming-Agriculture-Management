@model List<Firming_Solution.Domain.Entities.AppUser>
@using Firming_Solution.Domain.Enums
@{
    ViewData["Title"] = "ব্যবহারকারী ব্যবস্থাপনা";

    string RoleBn(UserRole r) => r switch {
        UserRole.SuperAdmin  => "সুপার অ্যাডমিন",
        UserRole.Manager     => "ম্যানেজার",
        UserRole.Worker      => "কর্মী",
        UserRole.Accountant  => "হিসাবরক্ষক",
        UserRole.Viewer      => "দর্শক",
        _ => r.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div class="small" style="color:var(--caw-text-muted)">মোট @Model.Count জন ব্যবহারকারী</div>
    <a asp-controller="Account" asp-action="Register" class="btn btn-caw-primary btn-sm">
        <i class="fas fa-user-plus me-1"></i>নতুন ব্যবহারকারী নিবন্ধন
    </a>
</div>

<div class="caw-card">
    <div class="caw-section-title"><i class="fas fa-users-cog me-2"></i>সিস্টেম ব্যবহারকারীগণ</div>
    <div class="table-responsive">
        <table class="caw-table">
            <thead>
                <tr><th>নাম</th><th>ব্যবহারকারীর নাম</th><th>ইমেইল</th><th>ভূমিকা</th><th>অবস্থা</th><th>যোগদানের তারিখ</th><th>কার্যক্রম</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td style="color:var(--caw-text)">@(u.FullName ?? "—")</td>
                        <td style="color:var(--caw-text-muted)">@u.UserName</td>
                        <td style="color:var(--caw-text-muted)">@u.Email</td>
                        <td>
                            <span class="caw-badge @(u.Role == UserRole.SuperAdmin ? "badge-active" : "badge-planning")">
                                @RoleBn(u.Role)
                            </span>
                        </td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="caw-badge badge-active">সক্রিয়</span>
                            }
                            else
                            {
                                <span class="caw-badge badge-closed">নিষ্ক্রিয়</span>
                            }
                        </td>
                        <td style="color:var(--caw-text-muted)">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <form asp-action="ToggleActive" method="post" class="d-inline"
                                  onsubmit="return confirm('@(u.IsActive ? "এই ব্যবহারকারীকে নিষ্ক্রিয়" : "এই ব্যবহারকারীকে সক্রিয়") করবেন?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button type="submit" class="btn btn-sm @(u.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(u.IsActive ? "নিষ্ক্রিয় করুন" : "সক্রিয় করুন")">
                                    <i class="fas @(u.IsActive ? "fa-user-slash" : "fa-user-check")"></i>
                                </button>
                            </form>

                            <form asp-action="ChangeRole" method="post" class="d-inline ms-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <select name="role" class="form-select form-select-sm d-inline-block"
                                        style="width:140px; display:inline-block !important;"
                                        onchange="this.form.submit()">
                                    @foreach (var role in Enum.GetValues<UserRole>())
                                    {
                                        if (u.Role == role)
                                        {
                                            <option value="@role" selected="selected">@RoleBn(role)</option>
                                        }
                                        else
                                        {
                                            <option value="@role">@RoleBn(role)</option>
                                        }
                                    }
                                </select>
                            </form>

                            <form asp-action="DeleteUser" method="post" class="d-inline ms-1"
                                  onsubmit="return confirm('@u.UserName — এই ব্যবহারকারীকে মুছে ফেলবেন? এটি পূর্বাবস্থায় ফেরানো যাবে না।')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@u.Id" />
                                <button type="submit" class="btn btn-outline-danger btn-sm"><i class="fas fa-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
