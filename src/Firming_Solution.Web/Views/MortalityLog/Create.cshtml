@model Firming_Solution.Domain.Entities.MortalityLog
@{
    ViewData["Title"] = "Log Mortality";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="caw-card" style="border-left:4px solid var(--caw-danger)">
            <div class="caw-section-title"><i class="fas fa-skull-crossbones me-2 text-danger"></i>Log Mortality</div>
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="BatchId" class="caw-form-label">Batch <span class="text-danger">*</span></label>
                    <select asp-for="BatchId" asp-items="ViewBag.Batches" class="form-select">
                        <option value="">-- Select Active Batch --</option>
                    </select>
                    <span asp-validation-for="BatchId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="LogDate" class="caw-form-label">Date <span class="text-danger">*</span></label>
                        <input asp-for="LogDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Count" class="caw-form-label">Count (Deaths) <span class="text-danger">*</span></label>
                        <input asp-for="Count" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Count" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Reason" class="caw-form-label">Reason / Cause</label>
                    <input asp-for="Reason" class="form-control" placeholder="Disease, injury, unknown..." />
                </div>

                <div class="mb-4">
                    <label asp-for="EstimatedLoss" class="caw-form-label">Estimated Financial Loss (৳)</label>
                    <input asp-for="EstimatedLoss" class="form-control" type="number" step="0.01" placeholder="0.00" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger flex-fill">
                        <i class="fas fa-save me-2"></i>Save Mortality Log
                    </button>
                    <a asp-controller="Batch" asp-action="Index" class="btn btn-outline-secondary flex-fill">
                        <i class="fas fa-times me-2"></i>Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
